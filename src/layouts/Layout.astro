---
interface Props {
	title?: string;
}

const { title = "how cbse rewrote rules to favor coempt eduteck" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="An investigative report on how CBSE manipulated tender guidelines to award the On Screen Marking contract to Coempt Eduteck (formerly Globarena)." />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;1,400&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
		
		<script is:inline>
			// Minimalist theme controller
			const theme = (() => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
					return 'dark';
				}
				return 'light';
			})();
			
			if (theme === 'dark') {
				document.documentElement.classList.add('dark');
			} else {
				document.documentElement.classList.remove('dark');
			}
			window.localStorage.setItem('theme', theme);
		</script>
	</head>
	<body>
		<!-- Elegant background gradients for a grand yet clean feel -->
		<div class="bg-gradient-radial pointer-events-none" aria-hidden="true"></div>
		
		<header class="header">
			<div class="header-inner">
				<a href="https://sarthaksidhant.com" target="_blank" class="logo-link">sarthak sidhant</a>
				<button id="theme-toggle" class="theme-toggle-btn" aria-label="Toggle theme">
					<span class="theme-icon-light">🔆</span>
					<span class="theme-icon-dark">🌙</span>
				</button>
			</div>
		</header>

		<main class="main-container">
			<article class="prose">
				<slot />
			</article>
		</main>

		<footer class="footer">
			<div class="footer-inner">
				<p>Written by Sarthak Sidhant</p>
				<p class="footer-muted">In the interest of public accountability, transparency, and data security.</p>
			</div>
		</footer>

		<script>
			const themeToggleBtn = document.getElementById('theme-toggle');
			themeToggleBtn?.addEventListener('click', () => {
				if (document.documentElement.classList.contains('dark')) {
					document.documentElement.classList.remove('dark');
					localStorage.setItem('theme', 'light');
				} else {
					document.documentElement.classList.add('dark');
					localStorage.setItem('theme', 'dark');
				}
			});
		</script>
	</body>
</html>

<style is:global>
	:root {
		--bg-bg: #fcfbfa; /* Soft warm cream */
		--bg-secondary: #f6f5f2;
		--text-primary: #1c1b1a;
		--text-secondary: #6e6b64;
		--border-color: #e8e6e0;
		--accent-color: #4f46e5; /* Deep rich indigo */
		--link-color: #312e81;
		--code-bg: #f6f5f2;
		--gradient-start: rgba(99, 102, 241, 0.05);
		--gradient-end: rgba(236, 72, 153, 0.02);
	}

	html.dark {
		--bg-bg: #09090b; /* Sophisticated zinc dark */
		--bg-secondary: #121215;
		--text-primary: #f4f4f5;
		--text-secondary: #a1a1aa;
		--border-color: #27272a;
		--accent-color: #818cf8;
		--link-color: #c7d2fe;
		--code-bg: #18181b;
		--gradient-start: rgba(99, 102, 241, 0.08);
		--gradient-end: rgba(236, 72, 153, 0.03);
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
		background-color: var(--bg-bg);
		color: var(--text-primary);
		transition: background-color 0.3s ease, color 0.3s ease;
	}

	body {
		font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
		line-height: 1.8;
		-webkit-font-smoothing: antialiased;
		position: relative;
		min-height: 100vh;
	}

	/* Minimalist Background Gradients - Simple & Grand */
	.bg-gradient-radial {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 800px;
		background: radial-gradient(circle at 50% -100px, var(--gradient-start) 0%, var(--gradient-end) 50%, transparent 100%);
		z-index: -10;
		pointer-events: none;
	}

	/* Header styling - Elegant, slim border with subtle gradient glow */
	.header {
		border-bottom: 1px solid var(--border-color);
		padding: 1.5rem 1rem;
		background-color: rgba(252, 251, 250, 0.8);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		position: sticky;
		top: 0;
		z-index: 50;
	}

	html.dark .header {
		background-color: rgba(9, 9, 11, 0.8);
	}

	.header-inner {
		max-width: 720px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.logo-link {
		font-family: 'JetBrains Mono', monospace;
		font-weight: 500;
		font-size: 0.9rem;
		text-decoration: none;
		color: var(--text-primary);
		letter-spacing: -0.01em;
		transition: color 0.2s ease;
	}

	.logo-link:hover {
		color: var(--accent-color);
	}

	.theme-toggle-btn {
		background: none;
		border: none;
		cursor: pointer;
		font-size: 1.1rem;
		padding: 0.25rem;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--text-primary);
		transition: transform 0.2s ease;
	}

	.theme-toggle-btn:hover {
		transform: scale(1.1);
	}

	.theme-icon-light {
		display: block;
	}

	.theme-icon-dark {
		display: none;
	}

	html.dark .theme-icon-light {
		display: none;
	}

	html.dark .theme-icon-dark {
		display: block;
	}

	/* Layout Container */
	.main-container {
		max-width: 720px;
		margin: 0 auto;
		padding: 4rem 1.5rem 8rem;
	}

	/* Grand yet Minimalist Typography styling */
	.prose {
		font-family: 'Lora', Georgia, serif;
		font-size: 1.2rem;
		line-height: 1.85;
		color: var(--text-primary);
	}

	.prose h1, .prose h2, .prose h3, .prose h4 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		color: var(--text-primary);
		font-weight: 800;
		letter-spacing: -0.03em;
		margin-top: 3.5rem;
		margin-bottom: 1.25rem;
		line-height: 1.25;
		display: inline-block;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.prose h1 {
		font-size: 2.85rem;
		margin-top: 1rem;
		margin-bottom: 2rem;
		display: block;
		background-image: linear-gradient(135deg, #111111 0%, #4b5563 100%);
	}

	html.dark .prose h1 {
		background-image: linear-gradient(135deg, #ffffff 0%, #9ca3af 100%);
	}

	.prose summary {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-weight: 800;
		font-size: 2.25rem;
		cursor: pointer;
		margin-top: 3.5rem;
		margin-bottom: 1.25rem;
		outline: none;
		display: inline-block;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		background-image: linear-gradient(135deg, #111111 0%, #4b5563 100%);
	}

	html.dark .prose summary {
		background-image: linear-gradient(135deg, #ffffff 0%, #9ca3af 100%);
	}

	.prose details {
		border: 1px solid var(--border-color);
		border-radius: 0.75rem;
		padding: 1.5rem;
		margin: 3.5rem 0;
		background-color: var(--bg-secondary);
		transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.prose details[open] {
		border-color: var(--accent-color);
	}

	.prose details .end-content-block {
		margin-top: 1.5rem;
		padding: 2rem 1.5rem;
		border-radius: 0.5rem;
		background-color: var(--bg-bg);
		border: 1px solid var(--border-color);
		animation: slideDown 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
		overflow: hidden;
	}

	@keyframes slideDown {
		from {
			opacity: 0;
			transform: translateY(-12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.prose h2 {
		font-size: 1.85rem;
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 0.5rem;
		margin-top: 4rem;
		display: block;
		-webkit-text-fill-color: initial;
		background-clip: initial;
		-webkit-background-clip: initial;
		background-image: none;
		position: relative;
	}

	.prose h2::after {
		content: "";
		position: absolute;
		bottom: -1px;
		left: 0;
		width: 60px;
		height: 2px;
		background: linear-gradient(90deg, #ea580c 0%, #7c3aed 100%);
	}

	html.dark .prose h2::after {
		background: linear-gradient(90deg, #fb923c 0%, #a78bfa 100%);
	}

	.prose h3 {
		font-size: 1.45rem;
		margin-top: 3rem;
		background-image: linear-gradient(135deg, #059669 0%, #0284c7 100%);
	}

	html.dark .prose h3 {
		background-image: linear-gradient(135deg, #34d399 0%, #38bdf8 100%);
	}

	.prose p {
		margin-bottom: 1.75rem;
	}

	.prose a {
		color: var(--accent-color);
		text-decoration: none;
		border-bottom: 1px solid var(--border-color);
		font-weight: 500;
		transition: all 0.2s ease;
	}

	.prose a:hover {
		color: var(--text-primary);
		border-bottom-color: var(--text-primary);
	}

	.prose hr {
		border: none;
		border-top: 1px solid var(--border-color);
		margin: 4rem 0;
		position: relative;
	}

	.prose hr::after {
		content: "✦ ✦ ✦";
		font-size: 0.85rem;
		color: var(--text-secondary);
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		background-color: var(--bg-bg);
		padding: 0 1rem;
		letter-spacing: 0.25em;
	}

	.prose ul, .prose ol {
		margin-bottom: 1.75rem;
		padding-left: 1.75rem;
	}

	.prose li {
		margin-bottom: 0.75rem;
	}

	.prose code {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.85em;
		background-color: var(--code-bg);
		padding: 0.2em 0.4em;
		border-radius: 0.25em;
		border: 1px solid var(--border-color);
		color: var(--accent-color);
	}

	.prose img {
		max-width: 100%;
		height: auto;
		display: block;
		margin: 3rem auto;
		border-radius: 0.5rem;
		border: 1px solid var(--border-color);
		box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
		transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
	}

	.prose img:hover {
		transform: scale(1.015);
	}

	html.dark .prose img {
		box-shadow: 0 10px 35px rgba(0, 0, 0, 0.3);
	}

	.prose strong {
		font-weight: 700;
	}

	.prose blockquote {
		border-left: 4px solid var(--accent-color);
		padding-left: 1.5rem;
		margin: 2.5rem 0;
		font-style: italic;
		color: var(--text-secondary);
		font-size: 1.25rem;
	}

	/* Footer styling */
	.footer {
		border-top: 1px solid var(--border-color);
		background-color: var(--bg-secondary);
		padding: 5rem 1rem;
		text-align: center;
		font-size: 0.95rem;
		color: var(--text-secondary);
	}

	.footer-inner {
		max-width: 720px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.footer-muted {
		font-size: 0.85rem;
		color: var(--text-secondary);
		opacity: 0.85;
	}
</style>
