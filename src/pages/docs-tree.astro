---
import fs from 'fs';
import path from 'path';
import TreeNode from '../components/TreeNode.astro';

function getFilesTree(dirPath: string, relativePath = ''): any[] {
  const items = fs.readdirSync(dirPath);
  const result: any[] = [];

  for (const item of items) {
    if (item.startsWith('.') || item.startsWith('~')) continue; // Skip hidden/temp files
    
    const absolutePath = path.join(dirPath, item);
    const itemRelativePath = path.join(relativePath, item);
    const stat = fs.statSync(absolutePath);

    if (stat.isDirectory()) {
      result.push({
        name: item,
        type: 'directory',
        children: getFilesTree(absolutePath, itemRelativePath),
        path: itemRelativePath
      });
    } else {
      result.push({
        name: item,
        type: 'file',
        size: (stat.size / 1024).toFixed(1) + ' KB',
        path: itemRelativePath
      });
    }
  }

  // Sort: directories first, then files
  return result.sort((a, b) => {
    if (a.type === b.type) return a.name.localeCompare(b.name);
    return a.type === 'directory' ? -1 : 1;
  });
}

const docsDir = path.resolve('public/docs');
const treeData = getFilesTree(docsDir);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tender Docs Explorer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      --bg: #ffffff;
      --text: #171717;
      --text-muted: #737373;
      --border: #e5e5e5;
      --hover: #f5f5f5;
      --accent: #4f46e5;
    }

    @media (prefers-color-scheme: dark) {
      :root {
        --bg: #09090b;
        --text: #f4f4f5;
        --text-muted: #a1a1aa;
        --border: #27272a;
        --hover: #18181b;
        --accent: #818cf8;
      }
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      background-color: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      padding: 1.5rem;
      font-size: 0.95rem;
    }

    .title-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.75rem;
      margin-bottom: 1.25rem;
    }

    .title {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 700;
      font-size: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .title svg {
      width: 1.2rem;
      height: 1.2rem;
      color: var(--accent);
    }

    .tree-container {
      list-style-type: none;
      padding-left: 0;
    }
  </style>
</head>
<body>
  <div class="title-row">
    <div class="title">
      <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"></path></svg>
      Tender Archive Documents
    </div>
  </div>

  <ul class="tree-container">
    {treeData.map((node) => <TreeNode node={node} />)}
  </ul>

  <script>
    // Expand/Collapse folder script
    document.querySelectorAll('.directory-node').forEach(node => {
      node.addEventListener('click', (e) => {
        const target = e.currentTarget;
        if (!target) return;
        const children = (target as any).nextElementSibling;
        if (children) {
          children.classList.toggle('expanded');
          const icon = (target as any).querySelector('.folder-toggle-icon');
          if (icon) {
            icon.textContent = children.classList.contains('expanded') ? '▼' : '▶';
          }
        }
      });
    });
  </script>
</body>
</html>
